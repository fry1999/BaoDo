# BaoDo Backend — Environment Variables
# Set these as environment variables or in appsettings.json (never commit secrets)

# Database (Supabase PostgreSQL)
ConnectionStrings__DefaultConnection=Host=db.your-project.supabase.co;Database=postgres;Username=postgres;Password=your-db-password;SSL Mode=Require

# Redis (optional — falls back to in-memory if not set)
ConnectionStrings__Redis=localhost:6379

# JWT
Jwt__Secret=your-super-secret-jwt-key-minimum-32-characters

# OpenAI (for AI coaching and dictionary features)
OpenAI__ApiKey=sk-...

# CORS
AllowedOrigins=http://localhost:3000,https://baodo.vn
